---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Home from '../../components/Home.astro';
import { SITE } from '../../site';
import { getPosts } from '../../lib/posts';

export const getStaticPaths = (async () => {
  const posts = await getPosts('fr');
  const totalPages = Math.max(1, Math.ceil((posts.length - 1) / SITE.postsPerPage));
  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
    props: { posts, page: i + 2 },
  }));
}) satisfies GetStaticPaths;

const { posts, page } = Astro.props as { posts: any[]; page: number };
---
<BaseLayout
  lang="fr"
  title={`Angélo Lima — Page ${page}`}
  description={SITE.descriptionFr}
  canonical={`/page/${page}/`}
  type="website"
  active="blog"
  altUrl="/en/"
  alternates={[
    { hreflang: 'fr', href: `/page/${page}/` },
    { hreflang: 'en', href: '/en/' },
  ]}
>
  <Home lang="fr" posts={posts} currentPage={page} />
</BaseLayout>
