---
import PageLayout from '../../layouts/PageLayout.astro';
import { getTagGroups } from '../../lib/tags';
import { postUrl, formatDate, isoDate } from '../../lib/posts';

const groups = await getTagGroups('fr');
const description =
  'Index complet des articles du blog organisés par tags : IA, Développement, Web, Tech, Personnel, Sécurité. Trouvez facilement les sujets qui vous intéressent.';
---
<PageLayout
  lang="fr"
  title="Articles par Tags"
  subtitle="Explorez les articles par thématique"
  description={description}
  canonical="/tags/"
  active="tags"
  altUrl="/en/tags/"
  breadcrumb={[{ name: 'Accueil', url: '/' }, { name: 'Tags', url: '/tags/' }]}
  alternates={[
    { hreflang: 'fr', href: '/tags/' },
    { hreflang: 'x-default', href: '/tags/' },
    { hreflang: 'en', href: '/en/tags/' },
  ]}
>
  {groups.map((g) => (
    <a href={`#${g.tag}`} class="btn btn-primary tag-btn"><i class="fas fa-tag" aria-hidden="true"></i>&nbsp;{g.tag}&nbsp;({g.posts.length})</a>
  ))}

  <div id="full-tags-list">
    {groups.map((g) => (
      <>
        <h2 id={g.tag} class="linked-section"><i class="fas fa-tag" aria-hidden="true"></i>&nbsp;{g.tag}&nbsp;({g.posts.length})</h2>
        <div class="post-list">
          {g.posts.map((post) => (
            <div class="tag-entry">
              <a href={postUrl(post)}>{post.data.title}</a>
              <div class="entry-date">
                <time datetime={isoDate(post.data.date)}>{formatDate(post.data.date, 'fr')}</time>
              </div>
            </div>
          ))}
        </div>
      </>
    ))}
  </div>
</PageLayout>
